FROM node:20-slim

# Install system dependencies: Python, Poppler, Tesseract OCR, and build tools
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    poppler-utils \
    tesseract-ocr \
    libgl1-mesa-glx \
    libglib2.0-0 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Set up working directory
WORKDIR /app

# Create and activate virtual environment for Python
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install Python dependencies
COPY scripts/requirements-ocr.txt ./scripts/
COPY medical_doc_generator/requirements.txt ./medical_doc_generator/
RUN pip install --no-cache-dir -r scripts/requirements-ocr.txt
RUN pip install --no-cache-dir -r medical_doc_generator/requirements.txt

# Install Node.js dependencies
COPY package*.json ./
RUN npm install

# Copy application source and build
COPY . .
RUN npm run build

# Final Stage
FROM node:20-slim

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    poppler-utils \
    tesseract-ocr \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy venv and dist from builder
COPY --from=0 /opt/venv /opt/venv
COPY --from=0 /app/dist /app/dist
COPY --from=0 /app/package*.json ./
COPY --from=0 /app/medical_doc_generator /app/medical_doc_generator
COPY --from=0 /app/scripts /app/scripts
COPY --from=0 /app/uploads /app/uploads

ENV PATH="/opt/venv/bin:$PATH"
RUN npm install --omit=dev

# Environment settings
ENV NODE_ENV=production
ENV PORT=3001
ENV PYTHON_PATH=python3

# Expose port
EXPOSE 3001

# Run the app
CMD ["node", "dist/app.js"]
